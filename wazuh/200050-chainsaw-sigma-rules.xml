<group name="windows,chainsaw,sigma,">
  <rule id="200050" level="3">
    <field name="integration">^chainsaw-sigma$</field>
    <description>Chainsaw Sigma scan event</description>
    <group>sigma,chainsaw,</group>
    <options>no_full_log</options>
  </rule>

  <rule id="200051" level="12">
    <if_sid>200050</if_sid>
    <field name="event.level">(?i)^(critical|high)$</field>
    <description>Chainsaw Sigma high/critical: $(event.name)</description>
    <group>sigma,chainsaw,</group>
    <options>no_full_log</options>
  </rule>

  <rule id="200052" level="5">
    <if_sid>200050</if_sid>
    <field name="event.level">(?i)^medium$</field>
    <description>Chainsaw Sigma medium: $(event.name)</description>
    <group>sigma,chainsaw,</group>
    <options>no_full_log</options>
  </rule>

  <rule id="200053" level="1">
    <if_sid>200051</if_sid>
    <field name="event.logsource.category">^driver_load$</field>
    <description>Suppress common high driver load false positives</description>
    <group>sigma,chainsaw,</group>
    <options>no_full_log</options>
  </rule>
</group>
