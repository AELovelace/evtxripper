# Sample environment file for ChainsawRealtimeWazuh.ps1
# Copy this to .env on the endpoint, then adjust paths and detection scope.
#
# Security note:
# - This file can contain operational paths and service-monitored log locations.
# - Restrict permissions and do not commit a real environment file with secrets.

# Chainsaw executable installed on the endpoint.
CHAINSAW_EXECUTABLE=C:\Program Files\socfortress\chainsaw\chainsaw.exe

# Sigma rules repository root and active rules folder.
# The realtime script uses CHAINSAW_SIGMA_PATH for detections and
# CHAINSAW_SIGMA_REPO only when CHAINSAW_UPDATE_SIGMA=true.
CHAINSAW_SIGMA_REPO=C:\Program Files\socfortress\chainsaw\sigma
CHAINSAW_SIGMA_PATH=C:\Program Files\socfortress\chainsaw\sigma\rules\windows

# Chainsaw release content installed alongside the binary.
CHAINSAW_MAPPING_FILE=C:\Program Files\socfortress\chainsaw\mappings\sigma-event-logs-all.yml
CHAINSAW_RULES_PATH=C:\Program Files\socfortress\chainsaw\rules

# Hunt execution defaults.
CHAINSAW_TIMEZONE=UTC
CHAINSAW_UPDATE_SIGMA=false
CHAINSAW_REALTIME_USE_CUSTOM_RULES=false

# Local EVTX source path to scan every run.
CHAINSAW_REALTIME_EVTX_PATH=C:\Windows\System32\winevt\Logs

# Rolling-window state file. Keep this on persistent local disk.
CHAINSAW_REALTIME_STATE_PATH=C:\Program Files\socfortress\chainsaw\chainsaw_realtime_state.json

# Wazuh-monitored NDJSON output log.
CHAINSAW_WAZUH_OUTPUT_LOG=C:\Program Files (x86)\ossec-agent\active-response\active-responses.log

# Forward only selected Sigma severities into Wazuh.
# Typical values: critical ; high,critical ; medium,high,critical
CHAINSAW_REALTIME_LEVELS=high,critical

# Optional generic logging values if shared with the rest of this repo.
LOG_LEVEL=INFO
LOG_FILE=C:\Program Files\socfortress\chainsaw\chainsaw-realtime.log